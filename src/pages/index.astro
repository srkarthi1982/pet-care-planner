---
import { AvButton, AvContainer } from "@ansiversa/components";
import AppShell from "../layouts/AppShell.astro";

const title = "Pet Care Planner | Ansiversa";
const description = "Keep pet routines, logs, and vet visits in one calm workspace.";
---

<AppShell title={title} description={description}>
  <section class="py-20 sm:py-28">
    <AvContainer size="narrow" className="space-y-8">
      <p class="text-xs uppercase tracking-[0.28em] text-slate-400">Lifestyle · Care · Trust</p>
      <h1 class="text-4xl font-semibold leading-tight text-white sm:text-6xl">Pet care that stays organized, even on busy weeks.</h1>
      <p class="max-w-2xl text-lg text-slate-300">
        Track pet basics, routines, care logs, and vet records in one premium mini-app built for calm daily use.
      </p>
      <div class="flex flex-wrap gap-3">
        <AvButton href="/app">Open workspace</AvButton>
      </div>
    </AvContainer>
  </section>
</AppShell>
